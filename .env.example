# Copy this file to .env and fill in your local credentials.
# Never commit the real .env file.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# AWS Academy Learner Lab temporary credentials.
# Refresh these whenever the Learner Lab session rotates them.
AWS_ACCESS_KEY_ID=your_learner_lab_access_key
AWS_SECRET_ACCESS_KEY=your_learner_lab_secret_key
AWS_SESSION_TOKEN=your_learner_lab_session_token
AWS_DEFAULT_REGION=us-east-1

# Manual Learner Lab budget reading from the lab page.
# The AWS Budgets API is often unavailable in Learner Lab accounts.
AWS_LEARNER_LAB_BUDGET_REMAINING_USD=50

# Optional: set once you create a project bucket for later EMR logs/results.
AWS_FLIGHT_DELAY_BUCKET=
